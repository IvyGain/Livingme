generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String          @id @default(cuid())
  email                  String          @unique
  name                   String?
  avatarUrl              String?
  isActive               Boolean         @default(true)
  stripeCustomerId       String?         @unique
  univaPaySubscriptionId String?         @unique
  role                   UserRole        @default(FREE_MEMBER)
  isHelper               Boolean         @default(false)
  ambassadorType         AmbassadorType?
  joinedAt               DateTime?
  /// Living Me の継続日数カウント基準日。新規会員は登録日、
  /// 既存会員は自身で指定した日（管理画面から一括設定可）。
  startDate              DateTime?
  lastLoginAt            DateTime?
  referrerId             String?
  password               String?
  referrer               User?           @relation("Referral", fields: [referrerId], references: [id])
  referrals              User[]          @relation("Referral")
  stripeEvents           StripeEvent[]
  univaPayEvents         UnivaPayEvent[]
  inviteTokens           InviteToken[]
  registrations          EventRegistration[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  chatMessages      ChatMessage[]
  withdrawalRequests WithdrawalRequest[]
  memberTags        UserMemberTag[]

  // NextAuth fields
  accounts          Account[]
  sessions          Session[]

  @@index([isActive])
  @@index([stripeCustomerId])
  @@index([univaPaySubscriptionId])
}

model UnivaPayEvent {
  id          String   @id  // UnivaPay の Webhook イベント ID（冪等性キー）
  type        String
  processedAt DateTime @default(now())
  payload     Json
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  role      UserRole  @default(MEMBER)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

enum UserRole {
  FREE_MEMBER  // 無料会員
  MEMBER       // 有料会員
  ADMIN        // 管理者
}

enum AmbassadorType {
  FREE
  REFERRAL
  PARTNER
}

model ContactInquiry {
  id        String         @id @default(cuid())
  name      String
  email     String
  subject   String
  body      String         @db.Text
  status    InquiryStatus  @default(OPEN)
  replies   InquiryReply[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
}

model InquiryReply {
  id          String         @id @default(cuid())
  inquiryId   String
  inquiry     ContactInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  content     String         @db.Text
  sentByEmail Boolean        @default(false)
  createdAt   DateTime       @default(now())

  @@index([inquiryId])
}

enum InquiryStatus {
  OPEN
  REPLIED
  CLOSED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
  payload     Json
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String   // Lark record_id（外部キーなし）
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   Json
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Setting {
  key       String   @id
  value     String
  isSecret  Boolean  @default(false)
  label     String
  updatedAt DateTime @updatedAt
}

/// 管理画面から作成する動的な申請フォーム定義。
/// fields は JSON（{ name, label, type, required, options? }[] 形式）。
/// larkTableId は任意：設定されていればそのテーブルに保存される。
model DynamicForm {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  description    String   @db.Text
  fields         Json
  ambassadorOnly Boolean  @default(false)
  larkTableId    String?
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isPublished])
}

model WithdrawalRequest {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason      String?          @db.Text
  status      WithdrawalStatus @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([userId])
}

enum WithdrawalStatus {
  PENDING
  PROCESSED
}

model ChatChannel {
  id           String        @id @default(cuid())
  name         String
  description  String?
  larkTableId  String?       // Lark Base のテーブルID（同期用）
  isArchived   Boolean       @default(false)
  requiredRole UserRole?     // null=全ログインユーザー閲覧可, FREE_MEMBER=無料以上, MEMBER=有料以上, ADMIN=管理者のみ
  writeRole    UserRole?     // null=全ログインユーザー書き込み可, FREE_MEMBER=無料以上, MEMBER=有料以上, ADMIN=管理者のみ
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isArchived])
}

model MemberTag {
  id        String          @id @default(cuid())
  name      String          @unique
  color     String          @default("#9a8070")
  users     UserMemberTag[]
  createdAt DateTime        @default(now())
}

model UserMemberTag {
  userId    String
  tagId     String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       MemberTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([userId, tagId])
  @@index([userId])
  @@index([tagId])
}

model ChatMessage {
  id           String        @id @default(cuid())
  channelId    String
  channel      ChatChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  content      String        @db.Text
  parentId     String?
  parent       ChatMessage?  @relation("Threads", fields: [parentId], references: [id])
  replies      ChatMessage[] @relation("Threads")
  larkRecordId String?
  editedAt     DateTime?
  createdAt    DateTime      @default(now())

  @@index([channelId, createdAt])
  @@index([parentId])
}
