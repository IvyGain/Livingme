# ──────────────────────────────────────────────────────────────────────
# Living Me — Environment Variables
# Copy to `.env.local` for development, or configure in your hosting
# provider (Vercel / AWS Amplify / ECS) for production.
# ──────────────────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────────────────

# NextAuth v5 secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# (Optional) Salt used to derive the AES-256-GCM key for the Setting table.
# If omitted, falls back to the legacy "livingme-settings" salt for
# backward compatibility. Set a random 32+ byte value for stronger
# encryption: openssl rand -base64 32
AUTH_SALT=

# PostgreSQL connection string (Neon / Supabase / RDS / local).
# Format: postgresql://user:password@host:5432/dbname?schema=public&sslmode=require
DATABASE_URL=

# Public URL of the deployed site (used by NextAuth for callbacks).
# Required in production. e.g. https://livingme.example.com
NEXTAUTH_URL=

# ─── Strongly recommended for 1000+ users ─────────────────────────────
# Upstash Redis (REST). Persists login rate-limit counters across instances.
# If unset, falls back to per-instance in-memory (not safe at scale).
# Setup: Vercel project > Storage > Upstash for Redis > Connect to Project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Lark Base integration ──────────────────────────────────
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_APP_TOKEN=
LARK_FORM_TABLE_ID=
LARK_API_BASE_URL=https://open.larksuite.com

# ─── Optional: UnivaPay (billing) ─────────────────────────────────────
UNIVAPAY_APP_TOKEN=
UNIVAPAY_APP_SECRET=
UNIVAPAY_PRICE=

# ─── Optional: Email ──────────────────────────────────────────────────
# (Configured via the admin UI's Settings page once running.)
